      "source": [
        "# Load the sentiment analysis pipeline\n",
        "sentiment_pipeline = pipeline(\"sentiment-analysis\", model=\"w11wo/indonesian-roberta-base-posp-tagger\")\n",
        "\n",
        "# Function to get sentiment from the pipeline output\n",
        "def get_sentiment(text):\n",
        "    if isinstance(text, str):\n",
        "        result = sentiment_pipeline(text)\n",
        "        return result[0]['label']\n",
        "    return None\n",
        "\n",
        "# Apply sentiment analysis to the 'content' column\n",
        "df_reviews['sentiment'] = df_reviews['content'].apply(get_sentiment)\n",
        "\n",
        "# Display the DataFrame with the new sentiment column\n",
        "print(\"\\nDataFrame with sentiment analysis results:\")\n",
        "display(df_reviews.head())"
